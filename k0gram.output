    TYPE_CAST
    RSQUARE


Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | ARRAY LT type GT

   18 val_var: VAL
   19        | VAR

   20 literal: INT
   21        | REAL
   22        | STRING
   23        | MULTI_STRING
   24        | CHAR

   25 bool_literal: K_TRUE
   26             | K_FALSE

   27 global_var_decl: val_var IDENT COLON type SEMICOLON
   28                | val_var IDENT COLON type ASSIGN expr SEMICOLON

   29 global_var_init: val_var IDENT ASSIGN expr SEMICOLON

   30 fun_body_var_decl: val_var IDENT COLON type SEMICOLON
   31                  | val_var IDENT COLON type ASSIGN expr SEMICOLON

   32 fun_body_var_init: val_var IDENT ASSIGN expr SEMICOLON

   33 function_var_decl: IDENT COLON type

   34 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   35              | FUN IDENT LPAREN parameter_list RPAREN function_body
   36              | FUN IDENT LPAREN parameter_list RPAREN SEMICOLON

   37 parameter_list: function_var_decl
   38               | parameter_list COMMA function_var_decl
   39               | ε

   40 function_body: LBRACE fun_body_var_list statement_list RBRACE

   41 fun_body_var_list: fun_body_var_list fun_body_var_decl
   42                  | fun_body_var_list fun_body_var_init
   43                  | ε

   44 statement_list: statement_list statement
   45               | ε

   46 statement: non_control_statement
   47          | loop_statement
   48          | if_statement
   49          | RETURN expr SEMICOLON

   50 non_control_statement: expr SEMICOLON

   51 expr: assignment_expr

   52 logical_or_expr: logical_and_expr
   53                | logical_or_expr OR logical_and_expr

   54 logical_and_expr: equality_expr
   55                 | logical_and_expr AND equality_expr

   56 equality_expr: relational_expr
   57              | equality_expr EQ relational_expr
   58              | equality_expr NEQ relational_expr

   59 relational_expr: additive_expr
   60                | relational_expr LT additive_expr
   61                | relational_expr GT additive_expr
   62                | relational_expr LTE additive_expr
   63                | relational_expr GTE additive_expr

   64 assignment_expr: logical_or_expr
   65                | IDENT ASSIGN assignment_expr
   66                | IDENT PLUS_ASSIGN assignment_expr
   67                | IDENT MINUS_ASSIGN assignment_expr

   68 additive_expr: multiplicative_expr
   69              | additive_expr PLUS multiplicative_expr
   70              | additive_expr MINUS multiplicative_expr

   71 multiplicative_expr: unary_expr
   72                    | multiplicative_expr MUL unary_expr
   73                    | multiplicative_expr DIV unary_expr
   74                    | multiplicative_expr MOD unary_expr

   75 unary_expr: primary_expr
   76           | MINUS unary_expr
   77           | NOT unary_expr
   78           | INC unary_expr
   79           | DEC unary_expr

   80 primary_expr: function_call
   81             | IDENT
   82             | literal
   83             | LPAREN expr RPAREN
   84             | bool_literal

   85 function_call: IDENT LPAREN function_call_values_list RPAREN

   86 function_call_values_list: functionCallVal
   87                          | function_call_values_list COMMA functionCallVal
   88                          | ε

   89 functionCallVal: literal
   90                | IDENT

   91 block: LBRACE statement_list RBRACE

   92 loop_statement: for_statement
   93               | while_statement

   94 for_statement: FOR LPAREN IDENT IN IDENT RANGE_INCL IDENT RPAREN control_structure_body
   95              | FOR LPAREN IDENT IN literal RANGE_INCL IDENT RPAREN control_structure_body
   96              | FOR LPAREN IDENT IN IDENT RANGE_INCL literal RPAREN control_structure_body
   97              | FOR LPAREN IDENT IN literal RANGE_INCL literal RPAREN control_structure_body

   98 while_statement: WHILE LPAREN expr RPAREN control_structure_body

   99 control_structure_body: block
  100                       | statement

  101 if_statement: IF LPAREN expr RPAREN control_structure_body
  102             | IF LPAREN expr RPAREN control_structure_body ELSE control_structure_body


