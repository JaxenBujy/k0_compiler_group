Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | ARRAY LT type GT

   18 val_var: VAL
   19        | VAR

   20 literal: INT
   21        | REAL
   22        | STRING
   23        | MULTI_STRING
   24        | CHAR

   25 global_var_decl: val_var IDENT COLON type
   26                | val_var IDENT COLON type ASSIGN literal
   27                | val_var IDENT COLON type ASSIGN IDENT

   28 global_var_init: val_var IDENT ASSIGN INT
   29                | val_var IDENT ASSIGN REAL
   30                | val_var IDENT ASSIGN CHAR

   31 fun_body_var_decl: val_var IDENT COLON type
   32                  | val_var IDENT COLON type ASSIGN literal
   33                  | val_var IDENT COLON type ASSIGN IDENT

   34 fun_body_var_init: val_var IDENT ASSIGN INT
   35                  | val_var IDENT ASSIGN REAL
   36                  | val_var IDENT ASSIGN CHAR

   37 function_var_decl: IDENT COLON type

   38 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   39              | FUN IDENT LPAREN parameter_list RPAREN function_body
   40              | FUN IDENT LPAREN parameter_list RPAREN

   41 parameter_list: function_var_decl
   42               | parameter_list COMMA function_var_decl
   43               | ε

   44 function_body: LBRACE fun_body_var_list stmt_list RBRACE

   45 fun_body_var_list: fun_body_var_list fun_body_var_decl
   46                  | fun_body_var_list fun_body_var_init
   47                  | ε

   48 stmt_list: stmt_list stmt
   49          | ε

   50 stmt: expr SEMICOLON
   51     | expr

   52 expr: function_call

   53 function_call: IDENT LPAREN function_call_values_list RPAREN

   54 function_call_values_list: functionCallVal
   55                          | function_call_values_list COMMA functionCallVal
   56                          | ε

   57 functionCallVal: literal
   58                | IDENT


