Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | ARRAY LT type GT

   18 val_var: VAL
   19        | VAR

   20 literal: INT
   21        | REAL
   22        | STRING
   23        | MULTI_STRING
   24        | CHAR

   25 bool_literal: K_TRUE
   26             | K_FALSE

   27 global_var_decl: val_var IDENT COLON type SEMICOLON
   28                | val_var IDENT COLON type ASSIGN literal SEMICOLON
   29                | val_var IDENT COLON type ASSIGN IDENT SEMICOLON

   30 global_var_init: val_var IDENT ASSIGN INT SEMICOLON
   31                | val_var IDENT ASSIGN REAL SEMICOLON
   32                | val_var IDENT ASSIGN CHAR SEMICOLON

   33 fun_body_var_decl: val_var IDENT COLON type SEMICOLON
   34                  | val_var IDENT COLON type ASSIGN literal SEMICOLON
   35                  | val_var IDENT COLON type ASSIGN IDENT SEMICOLON

   36 fun_body_var_init: val_var IDENT ASSIGN INT SEMICOLON
   37                  | val_var IDENT ASSIGN REAL SEMICOLON
   38                  | val_var IDENT ASSIGN CHAR SEMICOLON

   39 function_var_decl: IDENT COLON type

   40 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   41              | FUN IDENT LPAREN parameter_list RPAREN function_body
   42              | FUN IDENT LPAREN parameter_list RPAREN SEMICOLON

   43 parameter_list: function_var_decl
   44               | parameter_list COMMA function_var_decl
   45               | ε

   46 function_body: LBRACE fun_body_var_list statement_list RBRACE

   47 fun_body_var_list: fun_body_var_list fun_body_var_decl
   48                  | fun_body_var_list fun_body_var_init
   49                  | ε

   50 statement_list: statement_list statement
   51               | ε

   52 statement: non_control_statement
   53          | loop_statement
   54          | if_statement
   55          | RETURN expr SEMICOLON

   56 non_control_statement: expr SEMICOLON

   57 expr: assignment_expr

   58 logical_or_expr: logical_and_expr
   59                | logical_or_expr OR logical_and_expr

   60 logical_and_expr: equality_expr
   61                 | logical_and_expr AND equality_expr

   62 equality_expr: relational_expr
   63              | equality_expr EQ relational_expr
   64              | equality_expr NEQ relational_expr

   65 relational_expr: additive_expr
   66                | relational_expr LT additive_expr
   67                | relational_expr GT additive_expr
   68                | relational_expr LTE additive_expr
   69                | relational_expr GTE additive_expr

   70 assignment_expr: logical_or_expr
   71                | IDENT ASSIGN assignment_expr
   72                | IDENT PLUS_ASSIGN assignment_expr
   73                | IDENT MINUS_ASSIGN assignment_expr

   74 additive_expr: mulitplicative_expr
   75              | additive_expr PLUS mulitplicative_expr
   76              | additive_expr MINUS mulitplicative_expr

   77 mulitplicative_expr: unary_expr
   78                    | mulitplicative_expr MUL unary_expr
   79                    | mulitplicative_expr DIV unary_expr
   80                    | mulitplicative_expr MOD unary_expr

   81 unary_expr: primary_expr
   82           | MINUS unary_expr
   83           | NOT unary_expr
   84           | INC unary_expr
   85           | DEC unary_expr

   86 primary_expr: function_call
   87             | IDENT
   88             | literal
   89             | LPAREN expr RPAREN
   90             | bool_literal

   91 function_call: IDENT LPAREN function_call_values_list RPAREN

   92 function_call_values_list: functionCallVal
   93                          | function_call_values_list COMMA functionCallVal
   94                          | ε

   95 functionCallVal: literal
   96                | IDENT

   97 block: LBRACE statement_list RBRACE

   98 loop_statement: for_statement
   99               | while_statement

  100 for_statement: FOR LPAREN IDENT IN IDENT RANGE_INCL IDENT RPAREN control_structure_body
  101              | FOR LPAREN IDENT IN literal RANGE_INCL IDENT RPAREN control_structure_body
  102              | FOR LPAREN IDENT IN IDENT RANGE_INCL literal RPAREN control_structure_body
  103              | FOR LPAREN IDENT IN literal RANGE_INCL literal RPAREN control_structure_body

  104 while_statement: WHILE LPAREN expr RPAREN control_structure_body

  105 control_structure_body: block
  106                       | statement

  107 if_statement: IF LPAREN expr RPAREN control_structure_body
  108             | IF LPAREN expr RPAREN control_structure_body ELSE control_structure_body


