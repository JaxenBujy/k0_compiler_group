Terminals unused in grammar

    BREAK
    CONTINUE
    DO
    WHEN
    OP_ERROR
    ILL_IDENT
    UNCLOSED_COMMENT
    COULD_NOT_MATCH
    KEYWORD_ERROR
    NEG
    LSQUARE
    RSQUARE


Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | NULL_TYPE
   18     | CHAR_TYPE
   19     | ARRAY LT type GT

   20 val_var: VAL
   21        | VAR

   22 literal: INT
   23        | REAL
   24        | STRING
   25        | MULTI_STRING
   26        | CHAR
   27        | K_NULL
   28        | K_TRUE
   29        | K_FALSE

   30 global_var_decl: val_var IDENT COLON type SEMICOLON
   31                | val_var IDENT COLON type ASSIGN expr SEMICOLON
   32                | val_var IDENT COLON type NULLABLE SEMICOLON
   33                | val_var IDENT COLON type NULLABLE ASSIGN expr SEMICOLON

   34 global_var_init: val_var IDENT ASSIGN expr SEMICOLON

   35 fun_body_var_decl: val_var IDENT COLON type SEMICOLON
   36                  | val_var IDENT COLON type ASSIGN expr SEMICOLON
   37                  | val_var IDENT COLON type NULLABLE SEMICOLON
   38                  | val_var IDENT COLON type NULLABLE ASSIGN expr SEMICOLON

   39 fun_body_var_init: val_var IDENT ASSIGN expr SEMICOLON

   40 function_var_decl: IDENT COLON type
   41                  | IDENT COLON type NULLABLE

   42 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   43              | FUN IDENT LPAREN parameter_list RPAREN COLON type NULLABLE function_body
   44              | FUN IDENT LPAREN parameter_list RPAREN function_body

   45 parameter_list: function_var_decl
   46               | parameter_list COMMA function_var_decl
   47               | ε

   48 function_body: LBRACE fun_body_var_list statement_list RBRACE

   49 fun_body_var_list: fun_body_var_list fun_body_var_decl
   50                  | fun_body_var_list fun_body_var_init
   51                  | ε

   52 statement_list: statement_list statement
   53               | ε

   54 statement: non_control_statement
   55          | loop_statement
   56          | if_statement
   57          | RETURN expr SEMICOLON

   58 non_control_statement: expr SEMICOLON

   59 expr: assignment_expr

   60 assignment_expr: elvis_expr
   61                | IDENT ASSIGN assignment_expr
   62                | IDENT PLUS_ASSIGN assignment_expr
   63                | IDENT MINUS_ASSIGN assignment_expr

   64 elvis_expr: logical_or_expr
   65           | logical_or_expr ELVIS elvis_expr

   66 logical_or_expr: logical_and_expr
   67                | logical_or_expr OR logical_and_expr

   68 logical_and_expr: equality_expr
   69                 | logical_and_expr AND equality_expr

   70 equality_expr: relational_expr
   71              | equality_expr EQ relational_expr
   72              | equality_expr NEQ relational_expr
   73              | equality_expr REQ relational_expr
   74              | equality_expr RNEQ relational_expr

   75 relational_expr: range_expr
   76                | relational_expr LT range_expr
   77                | relational_expr GT range_expr
   78                | relational_expr LTE range_expr
   79                | relational_expr GTE range_expr

   80 range_expr: additive_expr
   81           | range_expr RANGE_INCL additive_expr
   82           | range_expr RANGE_EXCL additive_expr

   83 additive_expr: multiplicative_expr
   84              | additive_expr PLUS multiplicative_expr
   85              | additive_expr MINUS multiplicative_expr

   86 multiplicative_expr: unary_expr
   87                    | multiplicative_expr MUL unary_expr
   88                    | multiplicative_expr DIV unary_expr
   89                    | multiplicative_expr MOD unary_expr

   90 unary_expr: postfix_expr
   91           | MINUS unary_expr
   92           | NOT unary_expr
   93           | INC unary_expr
   94           | DEC unary_expr
   95           | TYPE_CAST unary_expr

   96 postfix_expr: primary_expr
   97             | postfix_expr INC
   98             | postfix_expr DEC
   99             | postfix_expr NN_ASSERT
  100             | postfix_expr NULLABLE
  101             | postfix_expr DOT IDENT
  102             | postfix_expr SAFE_CALL IDENT

  103 primary_expr: function_call
  104             | IDENT
  105             | literal
  106             | LPAREN expr RPAREN

  107 function_call: IDENT LPAREN function_call_values_list RPAREN

  108 function_call_values_list: functionCallVal
  109                          | function_call_values_list COMMA functionCallVal
  110                          | ε

  111 functionCallVal: literal
  112                | IDENT
  113                | LPAREN literal RPAREN DOT function_call

  114 block: LBRACE statement_list RBRACE

  115 loop_statement: for_statement
  116               | while_statement

  117 for_statement: FOR LPAREN IDENT IN IDENT RANGE_INCL IDENT RPAREN control_structure_body
  118              | FOR LPAREN IDENT IN literal RANGE_INCL IDENT RPAREN control_structure_body
  119              | FOR LPAREN IDENT IN IDENT RANGE_INCL literal RPAREN control_structure_body
  120              | FOR LPAREN IDENT IN literal RANGE_INCL literal RPAREN control_structure_body

  121 while_statement: WHILE LPAREN expr RPAREN control_structure_body

  122 control_structure_body: block
  123                       | statement

  124 if_statement: IF LPAREN expr RPAREN control_structure_body
  125             | IF LPAREN expr RPAREN control_structure_body ELSE control_structure_body


