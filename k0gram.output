Terminals unused in grammar

    BREAK
    CONTINUE
    DO
    K_NULL
    WHEN
    OP_ERROR
    ILL_IDENT
    UNCLOSED_COMMENT
    COULD_NOT_MATCH
    KEYWORD_ERROR
    NEG
    NN_ASSERT
    LSQUARE
    SAFE_CALL
    ELVIS
    NULLABLE
    RANGE_EXCL
    TYPE_CAST
    RSQUARE


Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | NULL_TYPE
   18     | ARRAY LT type GT

   19 val_var: VAL
   20        | VAR

   21 literal: INT
   22        | REAL
   23        | STRING
   24        | MULTI_STRING
   25        | CHAR

   26 bool_literal: K_TRUE
   27             | K_FALSE

   28 global_var_decl: val_var IDENT COLON type SEMICOLON
   29                | val_var IDENT COLON type ASSIGN expr SEMICOLON

   30 global_var_init: val_var IDENT ASSIGN expr SEMICOLON

   31 fun_body_var_decl: val_var IDENT COLON type SEMICOLON
   32                  | val_var IDENT COLON type ASSIGN expr SEMICOLON

   33 fun_body_var_init: val_var IDENT ASSIGN expr SEMICOLON

   34 function_var_decl: IDENT COLON type

   35 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   36              | FUN IDENT LPAREN parameter_list RPAREN function_body
   37              | FUN IDENT LPAREN parameter_list RPAREN SEMICOLON

   38 parameter_list: function_var_decl
   39               | parameter_list COMMA function_var_decl
   40               | literal
   41               | parameter_list COMMA literal
   42               | ε

   43 function_body: LBRACE fun_body_var_list statement_list RBRACE

   44 fun_body_var_list: fun_body_var_list fun_body_var_decl
   45                  | fun_body_var_list fun_body_var_init
   46                  | ε

   47 statement_list: statement_list statement
   48               | ε

   49 statement: non_control_statement
   50          | loop_statement
   51          | if_statement
   52          | RETURN expr SEMICOLON

   53 non_control_statement: expr SEMICOLON

   54 expr: assignment_expr

   55 logical_or_expr: logical_and_expr
   56                | logical_or_expr OR logical_and_expr

   57 logical_and_expr: equality_expr
   58                 | logical_and_expr AND equality_expr

   59 equality_expr: relational_expr
   60              | equality_expr EQ relational_expr
   61              | equality_expr NEQ relational_expr
   62              | equality_expr REQ relational_expr
   63              | equality_expr RNEQ relational_expr

   64 relational_expr: additive_expr
   65                | relational_expr LT additive_expr
   66                | relational_expr GT additive_expr
   67                | relational_expr LTE additive_expr
   68                | relational_expr GTE additive_expr

   69 assignment_expr: logical_or_expr
   70                | IDENT ASSIGN assignment_expr
   71                | IDENT PLUS_ASSIGN assignment_expr
   72                | IDENT MINUS_ASSIGN assignment_expr

   73 additive_expr: multiplicative_expr
   74              | additive_expr PLUS multiplicative_expr
   75              | additive_expr MINUS multiplicative_expr

   76 multiplicative_expr: unary_expr
   77                    | multiplicative_expr MUL unary_expr
   78                    | multiplicative_expr DIV unary_expr
   79                    | multiplicative_expr MOD unary_expr

   80 unary_expr: primary_expr
   81           | MINUS unary_expr
   82           | NOT unary_expr
   83           | INC unary_expr
   84           | DEC unary_expr

   85 primary_expr: function_call
   86             | IDENT
   87             | literal
   88             | LPAREN expr RPAREN
   89             | bool_literal
   90             | primary_expr INC
   91             | primary_expr DEC

   92 function_call: IDENT LPAREN function_call_values_list RPAREN

   93 function_call_values_list: functionCallVal
   94                          | function_call_values_list COMMA functionCallVal
   95                          | ε

   96 functionCallVal: literal
   97                | IDENT
   98                | LPAREN literal RPAREN DOT function_call

   99 block: LBRACE statement_list RBRACE

  100 loop_statement: for_statement
  101               | while_statement

  102 for_statement: FOR LPAREN IDENT IN IDENT RANGE_INCL IDENT RPAREN control_structure_body
  103              | FOR LPAREN IDENT IN literal RANGE_INCL IDENT RPAREN control_structure_body
  104              | FOR LPAREN IDENT IN IDENT RANGE_INCL literal RPAREN control_structure_body
  105              | FOR LPAREN IDENT IN literal RANGE_INCL literal RPAREN control_structure_body

  106 while_statement: WHILE LPAREN expr RPAREN control_structure_body

  107 control_structure_body: block
  108                       | statement

  109 if_statement: IF LPAREN expr RPAREN control_structure_body
  110             | IF LPAREN expr RPAREN control_structure_body ELSE control_structure_body


