Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | ARRAY LT type GT

   18 val_var: VAL
   19        | VAR

   20 literal: INT
   21        | REAL
   22        | STRING
   23        | MULTI_STRING
   24        | CHAR

   25 bool_literal: K_TRUE
   26             | K_FALSE

   27 global_var_decl: val_var IDENT COLON type SEMICOLON
   28                | val_var IDENT COLON type ASSIGN expr SEMICOLON

   29 global_var_init: val_var IDENT ASSIGN INT SEMICOLON
   30                | val_var IDENT ASSIGN REAL SEMICOLON
   31                | val_var IDENT ASSIGN CHAR SEMICOLON

   32 fun_body_var_decl: val_var IDENT COLON type SEMICOLON
   33                  | val_var IDENT COLON type ASSIGN expr SEMICOLON

   34 fun_body_var_init: val_var IDENT ASSIGN INT SEMICOLON
   35                  | val_var IDENT ASSIGN REAL SEMICOLON
   36                  | val_var IDENT ASSIGN CHAR SEMICOLON

   37 function_var_decl: IDENT COLON type

   38 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   39              | FUN IDENT LPAREN parameter_list RPAREN function_body
   40              | FUN IDENT LPAREN parameter_list RPAREN SEMICOLON

   41 parameter_list: function_var_decl
   42               | parameter_list COMMA function_var_decl
   43               | ε

   44 function_body: LBRACE fun_body_var_list statement_list RBRACE

   45 fun_body_var_list: fun_body_var_list fun_body_var_decl
   46                  | fun_body_var_list fun_body_var_init
   47                  | ε

   48 statement_list: statement_list statement
   49               | ε

   50 statement: non_control_statement
   51          | loop_statement
   52          | if_statement
   53          | RETURN expr SEMICOLON

   54 non_control_statement: expr SEMICOLON

   55 expr: assignment_expr

   56 logical_or_expr: logical_and_expr
   57                | logical_or_expr OR logical_and_expr

   58 logical_and_expr: equality_expr
   59                 | logical_and_expr AND equality_expr

   60 equality_expr: relational_expr
   61              | equality_expr EQ relational_expr
   62              | equality_expr NEQ relational_expr

   63 relational_expr: additive_expr
   64                | relational_expr LT additive_expr
   65                | relational_expr GT additive_expr
   66                | relational_expr LTE additive_expr
   67                | relational_expr GTE additive_expr

   68 assignment_expr: logical_or_expr
   69                | IDENT ASSIGN assignment_expr
   70                | IDENT PLUS_ASSIGN assignment_expr
   71                | IDENT MINUS_ASSIGN assignment_expr

   72 additive_expr: multiplicative_expr
   73              | additive_expr PLUS multiplicative_expr
   74              | additive_expr MINUS multiplicative_expr

   75 multiplicative_expr: unary_expr
   76                    | multiplicative_expr MUL unary_expr
   77                    | multiplicative_expr DIV unary_expr
   78                    | multiplicative_expr MOD unary_expr

   79 unary_expr: primary_expr
   80           | MINUS unary_expr
   81           | NOT unary_expr
   82           | INC unary_expr
   83           | DEC unary_expr

   84 primary_expr: function_call
   85             | IDENT
   86             | literal
   87             | LPAREN expr RPAREN
   88             | bool_literal

   89 function_call: IDENT LPAREN function_call_values_list RPAREN

   90 function_call_values_list: functionCallVal
   91                          | function_call_values_list COMMA functionCallVal
   92                          | ε

   93 functionCallVal: literal
   94                | IDENT

   95 block: LBRACE statement_list RBRACE

   96 loop_statement: for_statement
   97               | while_statement

   98 for_statement: FOR LPAREN IDENT IN expr RANGE_INCL expr RPAREN control_structure_body

   99 while_statement: WHILE LPAREN expr RPAREN control_structure_body

  100 control_structure_body: block
  101                       | statement

  102 if_statement: IF LPAREN expr RPAREN control_structure_body
  103             | IF LPAREN expr RPAREN control_structure_body ELSE control_structure_body


