Terminals unused in grammar

    BREAK
    CONTINUE
    DO
    K_NULL
    WHEN
    OP_ERROR
    ILL_IDENT
    UNCLOSED_COMMENT
    COULD_NOT_MATCH
    KEYWORD_ERROR
    NEG
    REQ
    RNEQ
    NN_ASSERT
    LSQUARE
    SAFE_CALL
    ELVIS
    NULLABLE
    RANGE_EXCL
    TYPE_CAST
    RSQUARE


Grammar

    0 $accept: program $end

    1 program: top_level_list

    2 top_level_list: top_level_list top_level_decl
    3               | top_level_decl

    4 top_level_decl: function_decl
    5               | importHeader
    6               | global_var_decl
    7               | global_var_init

    8 importHeader: IMPORT IDENT

    9 type: BYTE_TYPE
   10     | SHORT_TYPE
   11     | INT_TYPE
   12     | LONG_TYPE
   13     | FLOAT_TYPE
   14     | DOUBLE_TYPE
   15     | BOOLEAN_TYPE
   16     | STRING_TYPE
   17     | NULL_TYPE
   18     | ARRAY LT type GT

   19 val_var: VAL
   20        | VAR

   21 literal: INT
   22        | REAL
   23        | STRING
   24        | MULTI_STRING
   25        | CHAR

   26 bool_literal: K_TRUE
   27             | K_FALSE

   28 global_var_decl: val_var IDENT COLON type SEMICOLON
   29                | val_var IDENT COLON type ASSIGN expr SEMICOLON

   30 global_var_init: val_var IDENT ASSIGN expr SEMICOLON

   31 fun_body_var_decl: val_var IDENT COLON type SEMICOLON
   32                  | val_var IDENT COLON type ASSIGN expr SEMICOLON

   33 fun_body_var_init: val_var IDENT ASSIGN expr SEMICOLON

   34 function_var_decl: IDENT COLON type

   35 function_decl: FUN IDENT LPAREN parameter_list RPAREN COLON type function_body
   36              | FUN IDENT LPAREN parameter_list RPAREN function_body
   37              | FUN IDENT LPAREN parameter_list RPAREN SEMICOLON

   38 parameter_list: function_var_decl
   39               | parameter_list COMMA function_var_decl
   40               | ε

   41 function_body: LBRACE fun_body_var_list statement_list RBRACE

   42 fun_body_var_list: fun_body_var_list fun_body_var_decl
   43                  | fun_body_var_list fun_body_var_init
   44                  | ε

   45 statement_list: statement_list statement
   46               | ε

   47 statement: non_control_statement
   48          | loop_statement
   49          | if_statement
   50          | RETURN expr SEMICOLON

   51 non_control_statement: expr SEMICOLON

   52 expr: assignment_expr

   53 logical_or_expr: logical_and_expr
   54                | logical_or_expr OR logical_and_expr

   55 logical_and_expr: equality_expr
   56                 | logical_and_expr AND equality_expr

   57 equality_expr: relational_expr
   58              | equality_expr EQ relational_expr
   59              | equality_expr NEQ relational_expr

   60 relational_expr: additive_expr
   61                | relational_expr LT additive_expr
   62                | relational_expr GT additive_expr
   63                | relational_expr LTE additive_expr
   64                | relational_expr GTE additive_expr

   65 assignment_expr: logical_or_expr
   66                | IDENT ASSIGN assignment_expr
   67                | IDENT PLUS_ASSIGN assignment_expr
   68                | IDENT MINUS_ASSIGN assignment_expr

   69 additive_expr: multiplicative_expr
   70              | additive_expr PLUS multiplicative_expr
   71              | additive_expr MINUS multiplicative_expr

   72 multiplicative_expr: unary_expr
   73                    | multiplicative_expr MUL unary_expr
   74                    | multiplicative_expr DIV unary_expr
   75                    | multiplicative_expr MOD unary_expr

   76 unary_expr: primary_expr
   77           | MINUS unary_expr
   78           | NOT unary_expr
   79           | INC unary_expr
   80           | DEC unary_expr

   81 primary_expr: function_call
   82             | IDENT
   83             | literal
   84             | LPAREN expr RPAREN
   85             | bool_literal

   86 function_call: IDENT LPAREN function_call_values_list RPAREN

   87 function_call_values_list: functionCallVal
   88                          | function_call_values_list COMMA functionCallVal
   89                          | ε

   90 functionCallVal: literal
   91                | IDENT
   92                | LPAREN literal RPAREN DOT function_call

   93 block: LBRACE statement_list RBRACE

   94 loop_statement: for_statement
   95               | while_statement

   96 for_statement: FOR LPAREN IDENT IN IDENT RANGE_INCL IDENT RPAREN control_structure_body
   97              | FOR LPAREN IDENT IN literal RANGE_INCL IDENT RPAREN control_structure_body
   98              | FOR LPAREN IDENT IN IDENT RANGE_INCL literal RPAREN control_structure_body
   99              | FOR LPAREN IDENT IN literal RANGE_INCL literal RPAREN control_structure_body

  100 while_statement: WHILE LPAREN expr RPAREN control_structure_body

  101 control_structure_body: block
  102                       | statement

  103 if_statement: IF LPAREN expr RPAREN control_structure_body
  104             | IF LPAREN expr RPAREN control_structure_body ELSE control_structure_body


